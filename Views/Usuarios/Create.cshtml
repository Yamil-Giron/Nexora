@model Nexora.Models.Usuario

<h2>Crear Usuario</h2>

<form asp-action="Create" method="post">
    <div>
        <label asp-for="Nombres"></label>
        <input asp-for="Nombres" />
        <span asp-validation-for="Nombres" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Apellidos"></label>
        <input asp-for="Apellidos" />
        <span asp-validation-for="Apellidos" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Rut"></label>
        <input asp-for="Rut" />
        <span asp-validation-for="Rut" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Correo"></label>
        <input asp-for="Correo" type="email" />
        <span asp-validation-for="Correo" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Telefono"></label>
        <input asp-for="Telefono" type="tel" />
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Contraseña"></label>
        <input asp-for="Contraseña" type="password" />
        <span asp-validation-for="Contraseña" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Direccion"></label>
        <input asp-for="Direccion" />
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>
    <button type="submit">Guardar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
