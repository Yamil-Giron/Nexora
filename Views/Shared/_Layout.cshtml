<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Nexora</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                @if (Context.Session.GetString("UsuarioNombre") != null)
                {
                    <li>Hola @Context.Session.GetString("UsuarioNombre")!</li>
                    <li><a asp-controller="Auth" asp-action="Logout">Cerrar sesión</a></li>
                }
                else
                {
                    <li><a asp-controller="Auth" asp-action="Index">Ingreso / Registro</a></li>
                }
            </ul>
        </nav>
    </header>

    <main role="main" class="container">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; 2026 - Nexora</p>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
