@model Nexora.Models.Factura

<h2>Crear Factura</h2>

<form asp-action="Create">
    <div>
        <label asp-for="FechaEmision"></label>
        <input asp-for="FechaEmision" type="date" />
    </div>
    <div>
        <label asp-for="Monto"></label>
        <input asp-for="Monto" type="number" step="0.01" />
    </div>
    <div>
        <label asp-for="Estado"></label>
        <input asp-for="Estado" />
    </div>
    <div>
        <label>Contrato</label>
        <select asp-for="IdContrato" asp-items="ViewBag.Contratos"></select>
    </div>
    <button type="submit">Guardar</button>
</form>
